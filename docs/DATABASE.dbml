Project LifeStats {
  database_type: "PostgreSQL"
  Note: "Runtime-used tables only. Historical unused tables are intentionally omitted."
}

Table users {
  id bigint [pk, increment]
  name varchar(255) [not null]
  email varchar(255) [not null, unique]
  email_verified_at timestamptz
  password varchar(255) [not null]
  remember_token varchar(100)
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

Table admin_accounts_v1 {
  id smallint [pk]
  user_id bigint [not null, unique]
  created_at timestamptz [default: `now()`]
}

Table app_sessions {
  id uuid [pk]
  user_id bigint [not null]
  token_hash varchar(64) [not null, unique]
  csrf_token_hash varchar(64) [not null]
  expires_at timestamptz [not null]
  created_at timestamptz [default: `now()`]
  user_agent text

  indexes {
    user_id
    expires_at
  }
}

Table google_health_connections {
  id uuid [pk]
  user_id bigint [not null, unique]
  health_user_id text [unique]
  access_token text [not null, note: "Encrypted application token"]
  refresh_token text [note: "Encrypted application token"]
  expires_at timestamptz
  scope text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]

  indexes {
    user_id
  }
}

Table sync_jobs_v1 {
  id uuid [pk]
  user_id bigint [not null]
  status varchar(20) [not null, default: 'queued']
  requested_days integer [not null, default: 30]
  result jsonb
  error text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]

  indexes {
    user_id
    status
  }
}

Table tokens {
  id integer [pk]
  access_token text [note: "Legacy token retained for safe connection migration"]
  refresh_token text [note: "Legacy token retained for safe connection migration"]
  expiry bigint [note: "Unix epoch milliseconds"]
  scope text
  updated_at bigint [note: "Unix epoch milliseconds"]
}

Table meta {
  key text [pk]
  value text
}

Table daily_metrics {
  date text [not null, note: "ISO 8601 calendar date"]
  metric text [not null]
  value float
  updated_at bigint [note: "Unix epoch milliseconds"]

  indexes {
    (date, metric) [pk]
  }
}

Table health_records {
  id text [pk]
  data_type text [not null]
  start_time text [note: "ISO 8601 timestamp"]
  end_time text [note: "ISO 8601 timestamp"]
  date text [note: "ISO 8601 calendar date"]
  numeric_value float
  payload jsonb [not null]
  updated_at bigint [note: "Unix epoch milliseconds"]
}

Table exercises {
  id text [pk]
  type text
  display_name text
  start_time text [note: "ISO 8601 timestamp"]
  duration_s bigint
  calories float
  distance_mm float
  steps integer
  avg_hr integer
  raw jsonb
  updated_at bigint [note: "Unix epoch milliseconds"]
}

Table sync_state {
  data_type text [pk]
  last_synced_at bigint [note: "Unix epoch milliseconds"]
  status text [not null]
  record_count integer [default: 0]
  error text
  updated_at bigint [note: "Unix epoch milliseconds"]
}

Ref: admin_accounts_v1.user_id > users.id [delete: cascade]
Ref: app_sessions.user_id > users.id [delete: cascade]
Ref: google_health_connections.user_id > users.id [delete: cascade]
Ref: sync_jobs_v1.user_id > users.id [delete: cascade]
